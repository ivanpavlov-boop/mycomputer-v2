APP_NAME="MYCOMPUTER.BG"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mycomputer_v2
DB_USERNAME=root
DB_PASSWORD=root

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=local-meili-key

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=1300

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@mycomputer.bg"
MAIL_FROM_NAME="${APP_NAME}"

WEBHOOK_MOCK_SECRET=change-me

FEED_BASE_URL=http://localhost:8080/feeds
FEEDS_PUBLIC_BASE_URL=http://localhost:8080/feeds
GOOGLE_MERCHANT_FEED_URL=http://localhost:8080/feeds/google-merchant.xml
FACEBOOK_CATALOG_FEED_URL=http://localhost:8080/feeds/facebook-catalog.xml
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_PIXEL_ID=
META_CAPI_TOKEN=
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_GA4_ID=
NUXT_PUBLIC_META_PIXEL_ID=
