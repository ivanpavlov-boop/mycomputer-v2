APP_NAME="MYCOMPUTER.BG"
APP_ENV=staging
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_BOOTSTRAP
APP_DEBUG=false
APP_URL=https://staging.mycomputer.bg
FRONTEND_URL=https://staging.mycomputer.bg

APP_LOCALE=bg
APP_FALLBACK_LOCALE=bg
APP_FAKER_LOCALE=bg_BG

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mycomputer_v2
DB_USERNAME=root
DB_PASSWORD=change-this-staging-db-password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.staging.mycomputer.bg
SANCTUM_STATEFUL_DOMAINS=staging.mycomputer.bg
CORS_ALLOWED_ORIGINS=https://staging.mycomputer.bg

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change-this-meilisearch-key

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=1300

MAIL_MAILER=smtp
MAIL_HOST=change-this-smtp-host
MAIL_PORT=587
MAIL_USERNAME=change-this-smtp-user
MAIL_PASSWORD=change-this-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mycomputer.bg"
MAIL_FROM_NAME="${APP_NAME}"

EMAIL_MARKETING_PROVIDER=log
SUPPORT_CONTACT_EMAIL=support@mycomputer.bg
ABANDONED_CART_THRESHOLD_MINUTES=60
ABANDONED_CART_RECOVERY_TOKEN_DAYS=14
ABANDONED_CART_EXPIRE_AFTER_DAYS=14

WEBHOOK_MOCK_SECRET=change-this-webhook-secret

FEED_BASE_URL=https://staging.mycomputer.bg/feeds
FEEDS_PUBLIC_BASE_URL=https://staging.mycomputer.bg/feeds
GOOGLE_MERCHANT_FEED_URL=https://staging.mycomputer.bg/feeds/google-merchant.xml
FACEBOOK_CATALOG_FEED_URL=https://staging.mycomputer.bg/feeds/facebook-catalog.xml
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_PIXEL_ID=
META_CAPI_TOKEN=

NUXT_PUBLIC_API_BASE_URL=https://staging.mycomputer.bg/api/v1
NUXT_PUBLIC_SITE_URL=https://staging.mycomputer.bg
NUXT_PUBLIC_GA4_ID=
NUXT_PUBLIC_META_PIXEL_ID=
