APP_NAME="MYCOMPUTER.BG"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=bg
APP_FALLBACK_LOCALE=bg
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mycomputer_v2
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,127.0.0.1,127.0.0.1:3000,127.0.0.1:8000
SANCTUM_TOKEN_PREFIX=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=1300

CACHE_STORE=database
# CACHE_PREFIX=

SCOUT_DRIVER=database
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=1300

WEBHOOK_MOCK_SECRET=local-webhook-secret

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

EMAIL_MARKETING_PROVIDER=log
SUPPORT_CONTACT_EMAIL=support@mycomputer.bg
ABANDONED_CART_THRESHOLD_MINUTES=60
ABANDONED_CART_RECOVERY_TOKEN_DAYS=14
ABANDONED_CART_EXPIRE_AFTER_DAYS=14

APCOM_FEED_URL=https://example.invalid/apcom-feed.xml
SUPPLIER_FEED_HTTP_CONNECT_TIMEOUT=30
SUPPLIER_FEED_HTTP_TIMEOUT=300
CATALOG_SYNC_CREATE_ENABLED=true
CATALOG_SYNC_UPDATE_ENABLED=false
CATALOG_SYNC_SYNC_ALL_ENABLED=false
CATALOG_SYNC_AUTO_ENABLED=false
ASBIS_DUAL_FEED_STAGING_APPLY_ENABLED=false
FEED_BASE_URL=http://localhost/feeds
FEEDS_PUBLIC_BASE_URL=http://localhost/feeds
GOOGLE_MERCHANT_FEED_URL=http://localhost/feeds/google-merchant.xml
FACEBOOK_CATALOG_FEED_URL=http://localhost/feeds/facebook-catalog.xml
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
META_PIXEL_ID=
META_CAPI_TOKEN=
NUXT_PUBLIC_API_BASE_URL=/api/v1
NUXT_API_SERVER_BASE_URL=http://nginx/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:8080
NUXT_PUBLIC_GA4_ID=
NUXT_PUBLIC_META_PIXEL_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
